setTimeout(
    function(){
        if(document.getElementsByTagName('html')[0].getAttribute('lang') == 'en-EN' || document.getElementsByTagName('html')[0].getAttribute('lang') == 'en'){
            fontsettings = document.getElementById('bfschrifteinstellungen');
            fontsettings.innerText = 'Font settings'
            colorsettings = document.getElementById('bffarbeinstellungen');
            colorsettings.innerText = 'Color settings'
            contentsettings = document.getElementById('bfinhaltseinstellungen');
            contentsettings.innerText = 'Content settings'
            infobtn = document.getElementById('bfinfoBtn');
            infobtn.addEventListener('click', translateKeysButton);
            structurebtn = document.querySelector('.bfConfig button[data-bfc="bfSiteStructure"]');
            structurebtn.addEventListener('click', translateStructureButton);
        }
        anker = document.querySelector('.bfConfig button[data-bfc="bfSiteStructure"]');
        anker.addEventListener('click', ankerlink);
        const buttons = document.querySelectorAll(
            '.bfschrifteinstellungen button[data-bfc="bfLargerText"],' +
            '.bfschrifteinstellungen button[data-bfc="bfCharacterSpacing"],' +
            '.bfschrifteinstellungen button[data-bfc="bfLineSpacing"]'
        );
        buttons.forEach(btn => {
            btn.addEventListener('click', masonryUpdate);
        });
        masonryUpdate();
        const paginationbtn = document.querySelectorAll('.f3-widget-paginator > li');
        paginationbtn.forEach(btn => {
            btn.addEventListener('click', () => {
                const link = btn.querySelector('a');
                if (link) {
                    link.click();
                }
            });
        });
    }
, 0);

function translateKeysButton(){
  setTimeout(() => {
    const infoBoxKeys = document.querySelector('#bfInfoBoxKeys p:last-child strong');
    infoBoxKeys.textContent = 'If multiple identical elements are present on the same page, you can switch between them using this keyboard shortcut.';
  }, 0);
}
function translateStructureButton(){
  setTimeout(() => {
    const bfTab1 = document.getElementById('bfTab1');
    bfTab1.textContent = 'Headlines';
    const bfTab3 = document.getElementById('bfTab3');
    bfTab3.textContent = 'Contents';
  }, 0);
}
function ankerlink(){
    setTimeout(() => {
        const container = document.getElementById('bfStructure');
        if (container) {
            container.addEventListener('click', e => {
                const a = e.target.closest('a[href^="#"]');
                if (!a || !container.contains(a)) return;
                e.preventDefault();
                const id = a.getAttribute('href').slice(1);
                const target = document.getElementById(id);
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth' });
                    history.replaceState(null, '', '#'+id);
                }
            });
        }
  }, 0);
}